{
  "private": true,
  "workspaces": [
    "frontend",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^9.2.4",
    "husky": "^9.1.7",
    "shx": "^0.4.0"
  },
  "scripts": {
    "prepare": "husky || true",
    "audit:bundle": "node scripts/check-frontend-bundle.mjs",
    "audit:migrations": "node scripts/check-migration-history.mjs",
    "test:migrations": "node --test scripts/check-migration-history.test.mjs",
    "audit:supabase-usage": "node scripts/audit-supabase-usage.mjs",
    "dev": "concurrently -n api,web -c cyan,green \"npm run dev -w server\" \"npm run dev -w frontend -- --host 0.0.0.0 --port 5173\"",
    "dev:server": "npm run dev -w server",
    "dev:frontend": "npm run dev -w frontend -- --host 0.0.0.0 --port 5173",
    "build": "cd frontend && npm run build && cd .. && npm run audit:bundle && shx rm -rf public && shx cp -r frontend/dist public"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "pg-dump-restore-nodejs": "^0.0.10"
  }
}
